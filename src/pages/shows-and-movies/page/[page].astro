---
import ArchiveMain from '../../../components/ArchiveMain.astro';
import PageHead from '../../../components/PageHead.astro';
import { buildSearchItems, getPublishedPosts, sortPostsByDateDesc } from '../../../utils/posts';

export async function getStaticPaths() {
  const PAGE_SIZE = 10;
  const allPosts = sortPostsByDateDesc(await getPublishedPosts());
  const posts = allPosts.filter((post) => post.data.majorCategory === 'Shows and Movies');
  const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, idx) => {
    const page = idx + 2;
    const start = (page - 1) * PAGE_SIZE;
    const end = start + PAGE_SIZE;
    return {
      params: { page: String(page) },
      props: {
        currentPage: page,
        totalPages,
        posts: posts.slice(start, end),
      },
    };
  });
}

const { currentPage, totalPages, posts } = Astro.props as {
  currentPage: number;
  totalPages: number;
  posts: Awaited<ReturnType<typeof getPublishedPosts>>;
};

const base = import.meta.env.BASE_URL;
const allPosts = sortPostsByDateDesc(await getPublishedPosts());
const searchPosts = buildSearchItems(allPosts, base);
const siteOrigin = Astro.site?.toString() ?? 'http://127.0.0.1:4321';
const seoTitle = `Shows and Movies - Page ${currentPage} | whyself`;
const seoDescription = `Shows and movies archive page ${currentPage} on whyself.`;
const canonicalUrl = new URL(`${base}shows-and-movies/page/${currentPage}/`, siteOrigin).toString();
const ogImageUrl = new URL(`${base}images/hero/blog-hero-light-1920.webp`, siteOrigin).toString();
---
<!DOCTYPE html>
<html class="light" lang="en">
<head>
<PageHead
  base={base}
  title={seoTitle}
  description={seoDescription}
  canonicalUrl={canonicalUrl}
  ogType="website"
  ogImageUrl={ogImageUrl}
  twitterCard="summary_large_image"
/>
<style>
        body { font-family: 'Inter', sans-serif; }
        .serif-text { font-family: 'Newsreader', serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<ArchiveMain posts={posts} searchItems={searchPosts} base={base} currentPage={currentPage} totalPages={totalPages} majorRoute="shows-and-movies" />
</html>
