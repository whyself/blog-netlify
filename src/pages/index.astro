---
import ArchiveMain from '../components/ArchiveMain.astro';
import PageHead from '../components/PageHead.astro';
import { buildSearchItems, getPublishedPosts, sortPostsByDateDesc } from '../utils/posts';

const PAGE_SIZE = 10;
const base = import.meta.env.BASE_URL;
const allPosts = sortPostsByDateDesc(await getPublishedPosts());
const posts = allPosts.slice(0, PAGE_SIZE);
const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const currentPage = 1;
const searchPosts = buildSearchItems(allPosts, base);
const siteOrigin = Astro.site?.toString() ?? 'http://127.0.0.1:4321';
const seoTitle = 'Blog | whyself';
const seoDescription = 'Personal blog by whyself on growth, systems thinking, reading, film, and engineering practice.';
const canonicalUrl = new URL(base, siteOrigin).toString();
const ogImageUrl = new URL(`${base}images/hero/blog-hero-light-1920.webp`, siteOrigin).toString();
---
<!DOCTYPE html>
<html class="light" lang="en">
<head>
<PageHead
  base={base}
  title={seoTitle}
  description={seoDescription}
  canonicalUrl={canonicalUrl}
  ogType="website"
  ogImageUrl={ogImageUrl}
  twitterCard="summary_large_image"
/>
<style>
        body { font-family: 'Inter', sans-serif; }
        .serif-text { font-family: 'Newsreader', serif; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<ArchiveMain posts={posts} searchItems={searchPosts} base={base} currentPage={currentPage} totalPages={totalPages} />
</html>

