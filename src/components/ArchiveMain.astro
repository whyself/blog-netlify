---
import type { CollectionEntry } from 'astro:content';
import HeroBanner from './HeroBanner.astro';
import Icon from './Icon.astro';
import InitialViewportScript from './InitialViewportScript.astro';
import ProfileSidebar from './ProfileSidebar.astro';
import ScrollTopButton from './ScrollTopButton.astro';
import SiteFooter from './SiteFooter.astro';
import TopActions from './TopActions.astro';
import { recommendedReads } from '../data/recommended-reads';
import type { SearchItem } from '../utils/posts';

interface Props {
  posts: CollectionEntry<'posts'>[];
  searchItems: SearchItem[];
  base: string;
  currentPage: number;
  totalPages: number;
}

const { posts, searchItems, base, currentPage, totalPages } = Astro.props as Props;
const pageHref = (page: number) => (page <= 1 ? base : `${base}page/${page}/`);
---

<body class="bg-surface text-on-surface selection:bg-primary-container selection:text-white">
<TopActions searchItems={searchItems} />
<HeroBanner base={base} title="Blog" />
<main class="max-w-screen-2xl mx-auto flex flex-col lg:flex-row min-h-screen" data-content-start>
<ProfileSidebar active="home" />
<section class="flex-1 lg:-ml-16 lg:pl-0 lg:pr-0 py-8 md:py-12">
<div class="w-full mx-0 px-6 md:px-8 lg:pl-14 lg:pr-10 py-8 md:py-10 bg-surface-container-lowest dark:bg-zinc-900 border border-surface-container-high dark:border-zinc-700 rounded-sm">
<div class="mb-6">
<h1 class="font-headline font-black uppercase text-sm tracking-[0.2em] text-outline">ARCHIVES</h1>
</div>
<div class="mb-4 pb-2">
<div class="flex space-x-10 overflow-x-auto no-scrollbar">
<button class="font-label font-bold text-xs uppercase tracking-widest text-primary border-b-2 border-primary pb-4 whitespace-nowrap" data-major-filter="all" type="button">All Posts</button>
<button class="font-label font-bold text-xs uppercase tracking-widest text-outline hover:text-primary pb-4 transition-colors whitespace-nowrap" data-major-filter="articles" type="button">Articles</button>
<button class="font-label font-bold text-xs uppercase tracking-widest text-outline hover:text-primary pb-4 transition-colors whitespace-nowrap" data-major-filter="books" type="button">Books</button>
<button class="font-label font-bold text-xs uppercase tracking-widest text-outline hover:text-primary pb-4 transition-colors whitespace-nowrap" data-major-filter="shows-and-movies" type="button">Shows and Movies</button>
</div>
</div>
<nav class="mb-3 flex items-center justify-between pb-2">
{currentPage > 1 ? (
  <a class="font-label font-bold text-xs uppercase tracking-widest flex items-center space-x-2 text-outline hover:text-primary transition-colors" href={pageHref(currentPage - 1)}>
    <Icon class="w-4 h-4" name="arrow_back" />
    <span>Previous</span>
  </a>
) : (
  <span class="font-label font-bold text-xs uppercase tracking-widest flex items-center space-x-2 text-outline opacity-40 cursor-not-allowed">
    <Icon class="w-4 h-4" name="arrow_back" />
    <span>Previous</span>
  </span>
)}
{currentPage < totalPages ? (
  <a class="font-label font-bold text-xs uppercase tracking-widest flex items-center space-x-2 text-outline hover:text-primary transition-colors" href={pageHref(currentPage + 1)}>
    <span>Next</span>
    <Icon class="w-4 h-4" name="arrow_forward" />
  </a>
) : (
  <span class="font-label font-bold text-xs uppercase tracking-widest flex items-center space-x-2 text-outline opacity-40 cursor-not-allowed">
    <span>Next</span>
    <Icon class="w-4 h-4" name="arrow_forward" />
  </span>
)}
</nav>
<div class="space-y-16" id="post-list-top">
{posts.map((post) => {
  const detailHref = `${base}posts/${post.slug}/`;
  const title = post.data.listTitle ?? post.data.title;
  const majorKey = post.data.majorCategory.toLowerCase().replaceAll(" ", "-");
  const tagData = post.data.tags.join("||");
  return (
    <article class="group cursor-pointer" data-major={majorKey} data-post-card="" data-tags={tagData}>
      {post.data.thumbnail ? (
        <div class="flex flex-col md:flex-row md:items-start gap-8">
          <div class="flex-1 space-y-4 order-2 md:order-1">
            <div class="flex items-center space-x-4">
              <span class="font-label text-[10px] uppercase tracking-[0.2em] text-outline">{post.data.listDate}</span>
              <span class="w-1 h-1 bg-outline-variant rounded-full"></span>
              <span class="font-label text-[10px] uppercase tracking-[0.2em] text-outline">{post.data.wordCount}</span>
            </div>
            <h3 class="font-headline font-bold text-2xl md:text-3xl tracking-tight text-on-surface group-hover:underline underline-offset-8 transition-all">
              <a href={detailHref} class="hover:opacity-80 transition-opacity">{title}</a>
            </h3>
            <p class="serif-text text-on-surface-variant text-lg leading-relaxed max-w-2xl">{post.data.excerpt}</p>
            <div class="flex space-x-2 pt-2">
              {post.data.tags.map((tag) => (
                <span class="px-4 py-1.5 border border-surface-container-highest text-[9px] font-bold uppercase tracking-widest rounded-full text-on-surface-variant">{tag}</span>
              ))}
            </div>
          </div>
          <div class="w-full md:w-48 h-48 bg-surface-container shrink-0 order-1 md:order-2 overflow-hidden">
            <img alt={title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" decoding="async" height="192" loading="lazy" src={post.data.thumbnail} width="192"/>
          </div>
        </div>
      ) : (
        <div class="flex flex-col md:flex-row md:items-start gap-8">
          <div class="flex-1 space-y-4">
            <div class="flex items-center space-x-4">
              <span class="font-label text-[10px] uppercase tracking-[0.2em] text-outline">{post.data.listDate}</span>
              <span class="w-1 h-1 bg-outline-variant rounded-full"></span>
              <span class="font-label text-[10px] uppercase tracking-[0.2em] text-outline">{post.data.wordCount}</span>
            </div>
            <h3 class="font-headline font-bold text-2xl md:text-3xl tracking-tight text-on-surface group-hover:underline underline-offset-8 transition-all">
              <a href={detailHref}>{title}</a>
            </h3>
            <p class="serif-text text-on-surface-variant text-lg leading-relaxed max-w-2xl">{post.data.excerpt}</p>
            <div class="flex space-x-2 pt-2">
              {post.data.tags.map((tag) => (
                <span class="px-4 py-1.5 border border-surface-container-highest text-[9px] font-bold uppercase tracking-widest rounded-full text-on-surface-variant">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      )}
</article>
  );
})}
</div>
<nav class="mt-24 flex items-center justify-center border-t border-surface-container-high pt-12">
<div class="flex space-x-6 font-label font-bold text-xs">
{Array.from({ length: totalPages }, (_, i) => i + 1).map((pageNum) =>
  pageNum === currentPage ? (
    <span class="text-primary border-b border-primary">{String(pageNum).padStart(2, "0")}</span>
  ) : (
    <a class="text-outline hover:text-primary transition-colors" href={pageHref(pageNum)}>{String(pageNum).padStart(2, "0")}</a>
  )
)}
</div>
</nav>
</div>
</section>
<aside class="w-full lg:w-[24rem] xl:w-[26rem] p-6 lg:pl-6 lg:pr-4 lg:pt-12 lg:pb-8 lg:sticky lg:top-16 lg:h-fit">
<h4 class="font-headline font-black uppercase text-[10px] tracking-[0.3em] mb-8 text-on-surface">Categories</h4>
<div class="flex flex-wrap gap-3" id="tag-filters">
</div>
<div class="mt-16">
<h4 class="font-headline font-black uppercase text-[10px] tracking-[0.3em] mb-8 text-on-surface">Recent Reads</h4>
<ul class="space-y-6 font-body italic text-lg text-on-surface-variant">
{recommendedReads.map((item) => (
  <li class="leading-snug">
    <a
      class="hover:text-primary transition-colors"
      href={item.href}
      rel={/^https?:\/\//i.test(item.href) ? 'noopener noreferrer' : undefined}
      target={/^https?:\/\//i.test(item.href) ? '_blank' : undefined}
    >
      {item.title}
    </a>
  </li>
))}
</ul>
</div>
</aside>
</main>
<SiteFooter />
<ScrollTopButton />
<script is:inline>
  (() => {
    const cards = Array.from(document.querySelectorAll("[data-post-card]"));
    const majorButtons = Array.from(document.querySelectorAll("[data-major-filter]"));
    const tagContainer = document.getElementById("tag-filters");
    if (!cards.length || !majorButtons.length || !tagContainer) return;

    const tagSelectedClass = "px-5 py-2.5 bg-primary text-on-primary text-[10px] font-bold uppercase tracking-[0.15em] rounded-full shadow-sm";
    const tagUnselectedClass = "px-5 py-2.5 border border-surface-container-highest text-on-surface-variant hover:border-primary hover:text-primary transition-all text-[10px] font-bold uppercase tracking-[0.15em] rounded-full";
    const state = { major: "all", tag: "all" };

    const getTags = (card) => (card.getAttribute("data-tags") || "").split("||").filter(Boolean);

    const updateMajorButtons = () => {
      majorButtons.forEach((btn) => {
        const isActive = btn.dataset.majorFilter === state.major;
        btn.classList.toggle("border-b-2", isActive);
        btn.classList.toggle("border-primary", isActive);
        btn.classList.toggle("text-primary", isActive);
        btn.classList.toggle("text-outline", !isActive);
      });
    };

    const getAvailableTags = () => {
      const tagSet = new Set();
      cards.forEach((card) => {
        const major = card.getAttribute("data-major");
        if (state.major === "all" || major === state.major) {
          getTags(card).forEach((tag) => tagSet.add(tag));
        }
      });
      return Array.from(tagSet).sort((a, b) => a.localeCompare(b));
    };

    const applyFilters = () => {
      cards.forEach((card) => {
        const major = card.getAttribute("data-major");
        const tags = getTags(card);
        const majorMatch = state.major === "all" || major === state.major;
        const tagMatch = state.tag === "all" || tags.includes(state.tag);
        card.hidden = !(majorMatch && tagMatch);
      });

      updateMajorButtons();
      renderTagButtons();
    };

    const renderTagButtons = () => {
      const tags = getAvailableTags();
      if (state.tag !== "all" && !tags.includes(state.tag)) state.tag = "all";
      tagContainer.innerHTML = "";

      const buildTagButton = (label, value, active) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.dataset.tagFilter = value;
        btn.className = active ? tagSelectedClass : tagUnselectedClass;
        btn.textContent = label;
        btn.addEventListener("click", () => {
          state.tag = value;
          applyFilters();
        });
        return btn;
      };

      tagContainer.appendChild(buildTagButton("All", "all", state.tag === "all"));
      tags.forEach((tag) => tagContainer.appendChild(buildTagButton(tag, tag, state.tag === tag)));
    };

    majorButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        state.major = btn.dataset.majorFilter || "all";
        state.tag = "all";
        applyFilters();
      });
    });

    applyFilters();
  })();
</script>
<InitialViewportScript />
</body>
